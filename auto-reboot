#!/usr/bin/env bash
# auto-reboot - Schedule conditional system reboots via systemd timers
# Checks /var/run/reboot-required and uptime threshold; dry-run by default
# Requires: systemd-run (systemd-container package)
set -euo pipefail
shopt -s inherit_errexit

# Script metadata
declare -r VERSION=1.2.0
#shellcheck disable=SC2155 # realpath return checked by set -e
declare -r SCRIPT_PATH=$(realpath -- "$0")
declare -r SCRIPT_NAME=${SCRIPT_PATH##*/}

# Lock PATH to prevent command injection via PATH manipulation
declare -rx PATH='/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin'

# Configuration defaults (overridable via env vars or CLI options)
declare -- MACHINE_REBOOT_TIME=${MACHINE_REBOOT_TIME:-22:00}
declare -i MACHINE_UPTIME_MAXDAYS=${MACHINE_UPTIME_MAXDAYS:-14}

# Runtime state (frozen readonly after argument parsing)
declare -i REBOOT_NEEDED=0 DRY_RUN=1 FORCE_REBOOT=0 UPTIME_DAYS=0
declare -i VERBOSE=1
declare -a ALLOWED_DAYS=()  # Numeric days 0-6, 0=Sunday

# Audit trail: original invoking user
declare -r XUSER=${SUDO_USER:-${USER:-root}}

# Terminal colors
if [[ -t 1 && -t 2 ]]; then
  declare -r RED=$'\033[0;31m' CYAN=$'\033[0;36m' NC=$'\033[0m'
else
  declare -r RED='' CYAN='' NC=''
fi

# Messaging (all output to stderr; stdout reserved for data)
# _msg dispatches icon/color based on caller function name via FUNCNAME[1]
_msg() {
  local -- prefix="$SCRIPT_NAME:" msg
  case ${FUNCNAME[1]} in
    info)    prefix+=" ${CYAN}◉${NC}" ;;
    error)   prefix+=" ${RED}✗${NC}" ;;
    *)       ;;
  esac
  for msg in "$@"; do printf '%s %s\n' "$prefix" "$msg"; done
}
error() { >&2 _msg "$@"; }
info() { ((VERBOSE)) || return 0; >&2 _msg "$@"; }
die() { (($# < 2)) || error "${@:2}"; exit "${1:-0}"; }

# Argument validation helper
noarg() { (($# > 1)) || die 22 "Option ${1@Q} requires an argument"; }

# Display help text
usage() {
  cat <<HELP
$SCRIPT_NAME $VERSION - Intelligent system reboot scheduler

DESCRIPTION:
    Schedule conditional system reboots via systemd timers.
    Dry-run by default; use -N to execute.

    Reboot conditions:
      • System updates require reboot (/var/run/reboot-required)
      • Uptime exceeds maximum threshold
      • Manual force reboot request

    Features day-of-week restrictions, flexible scheduling,
    and comprehensive audit logging.

USAGE:
    $SCRIPT_NAME [OPTIONS]
    Designed for both interactive use and cron scheduling.

DEPENDENCIES:
    systemd-run (from systemd-container package)

OPTIONS:
    -f, --force-reboot
                  Unconditional reboot. Ignore reboot-required and uptime.
    -n, --dry-run
                  Dry run only. Do not execute (default is dry run).
    -N, --not-dry-run
                  Execute (not a dry run)
    -v, --verbose Verbose output (default)
    -q, --quiet   Suppress informational messages
    -h, --help    Show this help message
    -i, --install Install $SCRIPT_NAME to /usr/local/bin and dependencies
    -V, --version Show version information

    -m, --max-uptime-days DAYS
                  Maximum uptime in days before forced reboot (default: 14)
    -r, --reboot-time HH:MM
                  Time to schedule reboot in HH:MM format (default: 22:00)
    -a, --allowed-days DAYS
                  Restrict reboots to specific days of week
                  DAYS can be: Sun,Mon,Tue,Wed,Thu,Fri,Sat
                  Or: Sunday,Monday,Tuesday,Wednesday,Thursday,Friday,Saturday
                  Or: 0,1,2,3,4,5,6 (0=Sunday)
                  Multiple days: --allowed-days Sun,Mon,Fri

SCHEDULE MANAGEMENT:
    -l, --list    List all scheduled $SCRIPT_NAME timers
    -d, --delete TIMER
                  Delete a specific $SCRIPT_NAME timer
                  TIMER can be: full name (${SCRIPT_NAME}-1234.timer),
                  partial name (${SCRIPT_NAME}-1234), or just ID (1234)
    -D, --delete-all
                  Delete all scheduled $SCRIPT_NAME timers
                  (asks for confirmation)

ENVIRONMENT VARIABLES:
    MACHINE_REBOOT_TIME
                  Time to schedule reboot (default: 22:00)
                  Overridden by --reboot-time option
    MACHINE_UPTIME_MAXDAYS
                  Maximum uptime in days (default: 14)
                  Overridden by --max-uptime-days option

EXAMPLES:
    $SCRIPT_NAME --dry-run
    $SCRIPT_NAME --max-uptime-days 14 --reboot-time 04:20 --allowed-days Sun -N
    $SCRIPT_NAME --allowed-days Mon,Wed,Fri --reboot-time 22:30 -N

CRON EXAMPLE:
    # Add to root's crontab for weekly Sunday 4:20 AM reboot if uptime > 14 days
    15 23 * * * $SCRIPT_NAME --max-uptime-days 14 --reboot-time 04:20 --allowed-days Sun -N

HELP
  return 0
}

# Verify systemd-run is available; print install hints if missing
systemd_run_required() {
  if ! command -v systemd-run &>/dev/null; then
    error 'Requires systemd-run from package systemd-container'
    if id -nG "${USER:-}" | grep -qw sudo || ((EUID==0)); then
      >&2 echo
      info 'Run:'
      >&2 echo "sudo $SCRIPT_NAME --install"
      >&2 echo
      info 'Or:'
      >&2 echo 'sudo apt update && sudo apt install systemd-container'
    fi
    return 1
  fi
  return 0
}

# Parse day specification (Sun, Sunday, 0, etc.) to numeric day (0-6)
parse_day() {
  local -- day=$1
  case ${day,,} in
    sun|sunday|0) echo 0 ;;
    mon|monday|1) echo 1 ;;
    tue|tuesday|2) echo 2 ;;
    wed|wednesday|3) echo 3 ;;
    thu|thursday|4) echo 4 ;;
    fri|friday|5) echo 5 ;;
    sat|saturday|6) echo 6 ;;
    *) error "${FUNCNAME[1]}: Invalid day ${day@Q}. Use Sun-Sat, Sunday-Saturday, or 0-6."
      return 1
      ;;
  esac
}

# Parse comma-separated day list into ALLOWED_DAYS array
parse_allowed_days() {
  local -- day_list=$1
  local -- day
  local -a days=()
  local -- parsed_day
  declare -g ALLOWED_DAYS=()

  IFS=',' read -ra days <<< "$day_list"
  for day in "${days[@]}"; do
    # Trim whitespace (builtins preferred over sed/tr)
    day=${day#"${day%%[![:space:]]*}"}
    day=${day%"${day##*[![:space:]]}"}
    if parsed_day=$(parse_day "$day"); then
      ALLOWED_DAYS+=("$parsed_day")
    else
      return 1
    fi
  done
}

# Check if current day is in ALLOWED_DAYS array
is_reboot_day_allowed() {
  # No restrictions = any day allowed
  ((${#ALLOWED_DAYS[@]})) || return 0

  local -- current_day allowed_day
  current_day=$(date +'%w')  # 0-6, 0=Sunday

  for allowed_day in "${ALLOWED_DAYS[@]}"; do
    if (( current_day == allowed_day )); then return 0; fi
  done

  return 1
}

# Set REBOOT_NEEDED and UPTIME_DAYS based on system state
check_reboot_conditions() {
  # Globals modified inside function scope
  declare -g UPTIME_DAYS REBOOT_NEEDED
  if [[ -f /var/run/reboot-required ]]; then
    REBOOT_NEEDED=1
  fi

  # Check uptime threshold
  local -- uptime_start current_time
  uptime_start=$(date -d "$(uptime -s)" +'%s')
  current_time=$(date +'%s')
  UPTIME_DAYS=$(( (current_time - uptime_start) / 86400))

  if (( UPTIME_DAYS >= MACHINE_UPTIME_MAXDAYS )); then
    REBOOT_NEEDED=1
  fi

  # --force-reboot overrides all conditions
  if (( FORCE_REBOOT )); then
    REBOOT_NEEDED=1
  fi
}

# Calculate seconds until next reboot window
# Args: target_time (HH:MM) — Stdout: delay in seconds
# Returns 1 on invalid input or no valid day within 7 days
calculate_reboot_delay() {
  local -- target_time=$1
  local -i current_epoch target_epoch
  current_epoch=$(date +'%s')

  if [[ $target_time =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
    local -i hour=${BASH_REMATCH[1]}
    local -i minute=${BASH_REMATCH[2]}

    if (( ${#ALLOWED_DAYS[@]} == 0 )); then
      target_epoch=$(date -d "today ${hour}:${minute}" +'%s')

      if (( target_epoch <= current_epoch )); then
        target_epoch=$(date -d "tomorrow ${hour}:${minute}" +'%s')
      fi
    else
      local -i days_ahead=0 current_day=0 found=0
      current_day=$(date +'%w')

      # Try today first
      target_epoch=$(date -d "today ${hour}:${minute}" +'%s')
      if ((target_epoch > current_epoch)) && is_reboot_day_allowed; then
        found=1
      fi

      # Search up to 7 days ahead for next allowed day
      if (( ! found )); then
        local -i check_day
        local -- allowed_day
        for ((days_ahead=1; days_ahead<=7; days_ahead+=1)); do
          check_day=$(( (current_day + days_ahead) % 7 ))
          for allowed_day in "${ALLOWED_DAYS[@]}"; do
            if (( check_day == allowed_day )); then
              target_epoch=$(date -d "+${days_ahead} days ${hour}:${minute}" +'%s')
              found=1
              break 2
            fi
          done
        done
      fi

      if (( ! found )); then
        error 'No valid reboot day found in next 7 days'
        return 1
      fi
    fi

    echo "$((target_epoch - current_epoch))"
  else
    error "Invalid time format ${target_time@Q}. Use HH:MM format."
    return 1
  fi
}

# Schedule reboot via systemd-run transient timer
# Args: delay (seconds until reboot)
schedule_reboot() {
  local -i delay=$1
  local -- reboot_cmd="/sbin/shutdown -r now 'Scheduled reboot by $SCRIPT_NAME'"

  systemd_run_required || return 1

  # Allow running (0) or degraded (1) systemd states
  local -i sys_rc=0
  systemctl is-system-running &>/dev/null || sys_rc=$?
  if (( sys_rc > 1 )); then
    error 'systemd is not running. This script requires systemd for reliable scheduling.'
    return 1
  fi

  if (( ! DRY_RUN )); then
    logger -t "$SCRIPT_NAME" "Scheduling system reboot in ${delay}s for user $XUSER (uptime: ${UPTIME_DAYS}d)"

    if systemd-run --on-active="${delay}s" --timer-property=AccuracySec=1s \
      --unit="${SCRIPT_NAME}-$(date +%s)" \
      --description="Scheduled reboot by $SCRIPT_NAME" \
      bash -c "$reboot_cmd"; then
      logger -t "$SCRIPT_NAME" "Successfully scheduled reboot for $(date -d "now + ${delay} seconds" +'%F %T')"
      info "systemd-run: Reboot scheduled in ${delay} seconds"
    else
      error 'systemd-run: Failed to schedule reboot'
      return 1
    fi
  else
    info "systemd-run: [DRY RUN] Reboot scheduled in ${delay} seconds"
  fi
}

# List all scheduled auto-reboot timers
list_schedules() {
  local -i count=0
  local -- line

  echo "Active $SCRIPT_NAME schedules:"
  echo '============================='

  local -- timer_output
  timer_output=$(systemctl list-timers --all --no-pager 2>/dev/null | grep -E "${SCRIPT_NAME}-[0-9]+\.timer" ||:)
  
  if [[ -z "$timer_output" ]]; then
    echo "No active $SCRIPT_NAME schedules found."
    return 0
  fi
  
  local -- timer_name scheduled_time
  while IFS= read -r line; do
    count+=1
    timer_name=$(grep -o "${SCRIPT_NAME}-[0-9]*\.timer" <<< "$line")
    scheduled_time=$(awk '{print $1, $2, $3, $4}' <<< "$line")
    echo "$count. $timer_name - Scheduled: $scheduled_time"
  done <<< "$timer_output"
  
  echo '============================='
  echo "Total: $count scheduled reboot(s)"
}

# Delete a specific $SCRIPT_NAME timer
delete_schedule() {
  local -- timer_name=$1
  
  # Validate timer name format
  if [[ ! $timer_name =~ ^${SCRIPT_NAME}-[0-9]+\.timer$ ]]; then
    # If just the ID was provided, construct full name
    if [[ $timer_name =~ ^[0-9]+$ ]]; then
      timer_name="$SCRIPT_NAME"-"$timer_name".timer
    elif [[ $timer_name =~ ^${SCRIPT_NAME}-[0-9]+$ ]]; then
      timer_name="$timer_name".timer
    else
      error "Invalid timer name format. Use: ${SCRIPT_NAME}-TIMESTAMP or just TIMESTAMP"
      return 1
    fi
  fi
  
  # list-timers is more reliable than status for transient timers
  if ! systemctl list-timers --all --no-pager 2>/dev/null | grep -q "$timer_name"; then
    error "Timer $timer_name not found"
    return 1
  fi
  
  local -- service_name="${timer_name%.timer}".service
  
  info "Deleting $timer_name..."
  systemctl stop "$timer_name" 2>/dev/null ||:
  systemctl stop "$service_name" 2>/dev/null ||:
  
  logger -t "$SCRIPT_NAME" "Deleted scheduled reboot timer: $timer_name by user $XUSER"
  
  info "Successfully deleted $timer_name"
}

# Delete all $SCRIPT_NAME timers
delete_all_schedules() {
  local -i count=0
  local -a timers=()

  # Collect all $SCRIPT_NAME timers
  while IFS= read -r timer; do
    if [[ -n $timer ]]; then
      timers+=("$timer")
      count+=1
    fi
  done < <(systemctl list-timers --all --no-pager 2>/dev/null | grep -o "${SCRIPT_NAME}-[0-9]*\.timer")
  
  if (( count == 0 )); then
    info "No $SCRIPT_NAME schedules found to delete."
    return 0
  fi
  
  # Confirm deletion in non-dry-run mode
  if (( ! DRY_RUN )); then
    if [[ ! -t 0 ]]; then
      error 'Cannot prompt for confirmation in non-interactive mode'
      return 1
    fi
    echo "Found $count $SCRIPT_NAME schedule(s):"
    printf '%s\n' "${timers[@]}"
    echo
    read -p 'Delete all schedules? [y/N] ' -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      info 'Deletion cancelled.'
      return 0
    fi
  fi
  
  for timer in "${timers[@]}"; do
    delete_schedule "$timer"
  done
  
  logger -t "$SCRIPT_NAME" "Deleted all scheduled reboot timers ($count total) by user $XUSER"
  info "Deleted $count $SCRIPT_NAME schedule(s)."
}

# Install script to /usr/local/bin and ensure systemd-run is available
install_auto_reboot() {
  if ! command -v systemd-run &>/dev/null; then
    info 'Installing systemd-run (package systemd-container)'
    sudo apt-get update --quiet --assume-yes || {
      error 'apt-get update failed'
      return 1
    }
    sudo apt-get install --quiet --assume-yes systemd-container || {
      error 'Install systemd-run failed'
      return 1
    }
  fi
  if ! command -v systemd-run &>/dev/null; then
    error 'Could not find systemd-run'
    return 1
  fi
  info 'systemd-container is installed'

  local -- localbin=/usr/local/bin/"$SCRIPT_NAME"
  if [[ "$SCRIPT_PATH" != "$localbin" ]]; then
    [[ ! -L "$localbin" ]] || rm "$localbin"
    [[ ! -f "$localbin" ]] || rm "$localbin"
    ln -fs "$SCRIPT_PATH" "$localbin"
  fi
  chown "$XUSER":sudo "$SCRIPT_PATH"
  chmod 770 "$SCRIPT_PATH"
  chown "$XUSER":sudo -h "$localbin"
  chmod 770 "$localbin"

  info "$SCRIPT_NAME is installed at ${localbin@Q}"
  return 0
}

main() {
  # Auto-elevate to root via sudo if possible
  if ((EUID)); then
    if id -nG "${USER:-}" | grep -qw sudo; then
      sudo "$0" "$@"
      exit
    fi
    die 1 'Requires root/sudo access'
  fi

  local -i hour minute

  # Parse command line arguments
  while (($#)); do
    case $1 in
      -h|--help)
        usage
        return 0
        ;;
      -n|--dry-run|--dryrun)
        DRY_RUN=1 ;;
      -N|--not-dry-run|--notdryrun)
        DRY_RUN=0 ;;
      -v|--verbose)
        VERBOSE=1 ;;
      -q|--quiet)
        VERBOSE=0 ;;
      -f|--force-reboot)
        FORCE_REBOOT=1 ;;
      -m|--max-uptime-days)
        noarg "$@"; shift
        if [[ $1 =~ ^[0-9]+$ ]] && (( $1 > 0 )); then
          MACHINE_UPTIME_MAXDAYS=$1
        else
          error '--max-uptime-days must be a positive integer'; return 1
        fi ;;
      -r|--reboot-time)
        noarg "$@"; shift
        if [[ $1 =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
          hour=${BASH_REMATCH[1]}
          minute=${BASH_REMATCH[2]}
          if (( hour >= 0 && hour <= 23 && minute >= 0 && minute <= 59 )); then
            MACHINE_REBOOT_TIME=$1
          else
            error '--reboot-time must be valid time (00:00-23:59)'; return 1
          fi
        else
          error '--reboot-time must be in HH:MM format'; return 1
        fi ;;
      -a|--allowed-days)
        noarg "$@"; shift
        if ! parse_allowed_days "$1"; then
          return 1
        fi
        ;;
      # Standalone operations exit directly; parsing continues otherwise
      -i|--install)
        install_auto_reboot
        exit $?
        ;;
      -l|--list)
        list_schedules
        exit 0
        ;;
      -d|--delete)
        noarg "$@"; shift
        delete_schedule "$1"
        exit $?
        ;;
      -D|--delete-all)
        delete_all_schedules
        exit $?
        ;;
      -V|--version)
        echo "$SCRIPT_NAME $VERSION"
        exit 0
        ;;
      --) shift; break ;;
      -[hnNfvqmraildDV]?*) # Expand bundled short opts: -Nf becomes -N -f
        set -- "${1:0:2}" "-${1:2}" "${@:2}"
        continue
        ;;
      *)
        error "Unknown option ${1@Q}"
        usage
        return 1
        ;;
    esac
    shift
  done

  # Freeze configuration after argument parsing
  readonly -- MACHINE_REBOOT_TIME MACHINE_UPTIME_MAXDAYS
  readonly -- DRY_RUN FORCE_REBOOT VERBOSE
  readonly -a ALLOWED_DAYS

  systemd_run_required || return 1

  check_reboot_conditions

  if ((REBOOT_NEEDED)); then
    echo "Host: $HOSTNAME"
    echo 'Status: Reboot required'
    if [[ -f /var/run/reboot-required ]]; then
      echo '  - Reason: System updates require reboot'
    fi

    if ((UPTIME_DAYS >= MACHINE_UPTIME_MAXDAYS)); then
      echo "  - Reason: Uptime (${UPTIME_DAYS} days) exceeds maximum (${MACHINE_UPTIME_MAXDAYS} days)"
    fi

    (( !FORCE_REBOOT )) || echo '  - Reason: Force reboot requested'

    local -i delay
    local -- target_time
    if delay=$(calculate_reboot_delay "$MACHINE_REBOOT_TIME"); then
      target_time=$(date -d "now + ${delay} seconds" +'%F %T %Z')
      echo "Delay: $delay"
      echo "Scheduled: $target_time"

      schedule_reboot "$delay"

      if (( DRY_RUN )); then
        info "[DRY RUN] Use ${SCRIPT_NAME@Q} with option '-N' to execute"
      fi
    else
      error 'Failed to calculate reboot delay'
      return 1
    fi
  else
    echo "Host: $HOSTNAME"
    echo "Uptime: $(uptime -p)"
    echo "Reboot-required: $( [[ -f /var/run/reboot-required ]] && echo present || echo absent)"
    echo 'Status: Reboot not required'
  fi
}

main "$@"
#fin
